# Production environment variables
# Copy this to .env.prod and update values
DB_USER=prod_user
DB_PASSWORD=prod_super_secure_password
DB_NAME=prod_db
TIMEZONE=Europe/Prague

DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}

TARGET_CLUB=TARGET_CLUB
PROXY_NETWORK=DEF_PROXY_NETWORK
LOKI_ENABLED=false
LOKI_URL=loki:3100

SERVER_NAME=domain.cz

# API URL for frontend 
VITE_API_BASE_URL=http://${SERVER_NAME}

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://${SERVER_NAME},https://${SERVER_NAME}


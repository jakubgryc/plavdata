# Production environment variables
# Copy this to .env.prod and update values

DB_NAME=plavdata.db
DB_PATH=/app/data/${DB_NAME}
DATABASE_URL=sqlite:///${DB_PATH}

# Server domain name (used by nginx)
SERVER_NAME=yourdomain.cz

# API URL for frontend (must match SERVER_NAME)
VITE_API_BASE_URL=https://${SERVER_NAME}
# Or without SSL: VITE_API_BASE_URL=http://${SERVER_NAME}

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://${SERVER_NAME},http://${SERVER_NAME}

